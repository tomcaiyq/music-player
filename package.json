{
  "name": "music-player",
  "version": "1.0.0",
  "description": "云音乐播放器",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -n back,front -c blue,green \"npm run dev:back\" \"npm run dev:front\"",
    "dev:back": "cd backend && npm run dev",
    "dev:front": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "npm run build && npm run start:back",
    "start:back": "cd backend && npm start",
    "electron:dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.music-player.app",
    "productName": "云音乐",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "!backend/data/**",
      "!backend/uploads/**",
      "frontend/dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "backend/**/*",
      "!backend/data/**",
      "!backend/uploads/**",
      "frontend/dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "electron/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "云音乐",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
